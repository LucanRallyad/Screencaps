# --- Core
DATABASE_URL=postgres://postgres:postgres@localhost:5432/screencaps
SESSION_SECRET=replace-with-a-long-random-string-at-least-32-characters
BASE_URL=http://localhost:3000

# --- Portal SSO (REQUIRED)
# Shared HMAC secret used to verify SSO tickets issued by the Internal Portal.
# Must exactly match SSO_SECRET_SCREENCAPS in the Portal backend's env.
# Generate with: openssl rand -hex 32
SSO_SECRET_SCREENCAPS=CHANGE_ME_TO_64_HEX_CHARS

# --- Internal Portal URL (optional)
# Powers the "Back to Portal" top-bar link and the signed-out screen. When
# unset, both are simply hidden.
NEXT_PUBLIC_PORTAL_URL=https://portal.rallyadmedia.com

# --- Admin (seeded automatically on first run)
# Seeds a local admin PROFILE (no password). Signs in via the Internal Portal;
# the row links by email on first SSO login.
ADMIN_EMAIL=lucan@rallyad.com

# --- Email (Brevo)
# Non-auth project-complete notifications only. If BREVO_API_KEY is empty,
# emails are logged to the console instead of sent.
BREVO_API_KEY=
BREVO_FROM="Screencaps <noreply@rallyadmedia.com>"

# --- Storage (local fs for now)
UPLOAD_DIR=./uploads
SCREENSHOT_DIR=./screenshots

# --- Worker
WORKER_CONCURRENCY=3
PLAYWRIGHT_HEADLESS=true
